# ========== 应用 ==========
APP_NAME=ColdChain-QA
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========== PostgreSQL + pgvector ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=coldchain
POSTGRES_USER=coldchain
POSTGRES_PASSWORD=coldchain123
DATABASE_URL=postgresql+psycopg://coldchain:coldchain123@localhost:5432/coldchain

# ========== Embedding（CPU 推理，节省 4060 显存） ==========
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=512

# ========== LLM（Ollama 本地推理） ==========
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:12434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_LORA_MODEL=coldchain-qwen2.5:3b
TEMPERATURE=0.1
MAX_TOKENS=1024

# ========== RAG ==========
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=6
BM25_ENABLED=true
HYDE_ENABLED=false

# ========== 路径 ==========
DATA_DIR=./data
CACHE_DIR=./cache
MODELS_DIR=./models

# ========== LoRA 训练（RTX 4060 8GB 轻量化） ==========
LORA_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
LORA_OUTPUT_DIR=./models/lora_adapter
LORA_R=8
LORA_ALPHA=16
LORA_EPOCHS=3
LORA_BATCH_SIZE=1
LORA_GRAD_ACCUM=8
LORA_MAX_SEQ_LEN=1536
LORA_4BIT=true
